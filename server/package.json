{
  "name": "server",
  "private": true,
  "version": "2.1.1",
  "author": "Avdhesh Varshney",
  "license": "ISC",
  "description": "Code A2Z is a collaborative blogging platform for developers and writers to create, manage, and share projects with markdown support, customizable templates, and community contributions.",
  "keywords": [
    "code-a2z",
    "code a2z",
    "collaboration",
    "platform",
    "open-source",
    "projects"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "type": "module",
  "main": "index.js",
  "scripts": {
    "test": "MONGODB_URL=mongodb://localhost:27017/code_a2z_test node --test src/__tests__/api.test.js",
    "start": "node index.js",
    "dev": "nodemon index.js",
    "seed:default-org": "node src/db/seed-default-org.js",
    "migrate:org-id": "node src/db/migrate-org-id.js",
    "build": "echo 'No build process required'",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:build": "docker-compose build",
    "docker:restart": "docker-compose restart",
    "seed:dev": "node src/db/seed-dev.js",
    "approve-request": "node src/db/approve-request.js"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.5.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.11.0",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.1.2",
    "nodemailer": "^7.0.5",
    "rate-limiter-flexible": "^7.3.0",
    "resend": "^6.1.2",
    "sanitize-html": "^2.17.0",
    "socket.io": "^4.7.5",
    "winston": "^3.18.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.10",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  }
}
